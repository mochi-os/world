#!/usr/bin/env bash
# Deploy the published mochi-world package to yuzu via its local
# file:/srv/apt repo (already rsync'd there by `make release`), verified.
# Each `apt install` runs the package prerm/postinst, which gracefully
# restarts mochi-world.
#
# Invoked by `make -C world deploy`, the single allow-listed entry point for
# the production deploy: the ssh calls run inside the allowed make process
# rather than as separately-gated production writes. Extra apt flags (e.g.
# --reinstall to redeploy an identical version on `/world-release same`) are
# passed as arguments.
set -euo pipefail

flags="$*"

deploy() {
	local host="$1" role="$2"
	echo "=== Deploying mochi-world to $host ($role) ==="
	ssh "root@$host" "apt update && apt install -y $flags mochi-world"
	ssh "root@$host" "dpkg-query -W -f='$host mochi-world \${Version}\n' mochi-world; systemctl is-active mochi-world"
}

deploy yuzu.mochi-os.org primary
